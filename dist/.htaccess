Options -Indexes
RewriteEngine On

# Force non-www canonical host
RewriteCond %{HTTP_HOST} ^www\.shvedko\.dev$ [NC]
RewriteRule ^ https://shvedko.dev%{REQUEST_URI} [L,R=301]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove /index.html → canonical trailing-slash URL
RewriteCond %{THE_REQUEST} \s/(.+/)?index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Enforce trailing slash on directory-style URLs (skip files and craftly sub-pages)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !\.(html|css|js|png|jpg|jpeg|svg|ico|webp|woff|woff2|ttf|eot|xml|txt|json)$
RewriteCond %{REQUEST_URI} !^/craftly
RewriteRule ^(.+)$ /$1/ [R=301,L]

# Clean error pages
ErrorDocument 404 /404.html
